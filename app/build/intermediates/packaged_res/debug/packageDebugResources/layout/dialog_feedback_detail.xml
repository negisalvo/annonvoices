<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/colorSurface">

    <!-- Drag Handle / Accent Bar -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@color/gray_300" />

    <!-- Category Accent Tag & Date row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvDetailCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMPLAINT"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/cat_complaint"
            android:background="@color/primary_light"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvDetailDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="May 24, 2026 05:00 AM"
            android:textSize="12sp"
            android:textColor="@color/gray_500" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Student Submission:"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/gray_400"
        android:layout_marginBottom="8dp" />

    <!-- Scrollable full message -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="240dp"
        android:layout_marginBottom="24dp"
        android:background="@color/gray_50"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDetailMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Full message content here..."
            android:textSize="16sp"
            android:textColor="@color/gray_900"
            android:textIsSelectable="true"
            android:lineSpacingMultiplier="1.25" />
    </androidx.core.widget.NestedScrollView>

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <!-- Mark as Read Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailMarkRead"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Mark as Read"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="10dp" />

        <!-- Copy Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailCopy"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginEnd="6dp"
            android:text="Copy"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textColor="@color/primary"
            app:strokeColor="@color/primary"
            app:cornerRadius="10dp" />

        <!-- Delete Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailDelete"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:text="Delete"
            android:textColor="@color/cat_complaint"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="10dp" />

    </LinearLayout>

</LinearLayout>
